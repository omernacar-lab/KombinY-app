{
  "expo": {
    "name": "Kombin",
    "slug": "kombin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#6C63FF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kombin.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Kıyafet fotoğrafı çekmek için kamera erişimi gerekli.",
        "NSPhotoLibraryUsageDescription": "Gardırobunuza kıyafet eklemek için galeri erişimi gerekli."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF"
      },
      "package": "com.kombin.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "scheme": "kombin",
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store"
    ]
  }
}
