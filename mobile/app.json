{
  "expo": {
    "name": "Kombin",
    "slug": "kombin",
    "owner": "namelessone03",
    "icon": "./assets/logo.png",
    "extra": {
      "eas": {
        "projectId": "5569bfa9-313a-46c8-b177-1b5cb61a9421"
      }
    },
    "version": "1.0.0",
